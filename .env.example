# Port the Node server listens on (nginx proxies to this)
PORT=3000

# Superblocks embed token (server only — never commit real values)
SB_EMBED_TOKEN=

# Your Superblocks app embed URL (must include /embed/applications/, not /applications/ alone)
# Example: https://app.superblocks.com/code-mode/embed/applications/<APP_ID>
REACT_APP_SUPERBLOCKS_EMBED_SRC=

# Optional: override Superblocks token endpoint (e.g. for EU region)
# SUPERBLOCKS_TOKEN_URL=https://eu.superblocks.com/api/v1/public/token

# --- Auth ---
REACT_APP_AUTH_MODE=okta
REACT_APP_OKTA_ISSUER=https://<okta-domain>/oauth2/default
REACT_APP_OKTA_CLIENT_ID=
# Optional JWT audience for /api/superblocks/token (default: api://default)
# REACT_APP_OKTA_AUDIENCE=api://default

# --- Database ---
# NeonDB pooled connection string (used to look up sys_id by email)
DATABASE_URL=
