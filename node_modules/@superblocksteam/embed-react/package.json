{
  "name": "@superblocksteam/embed-react",
  "version": "1.2.2",
  "description": "This repo contains the Superblocks Embedded Apps React SDK",
  "homepage": "https://docs.superblocks.com/applications/embedded-apps",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "/dist"
  ],
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint:fix": "eslint . --ext .ts --config .eslintrc.json --fix",
    "lint": "eslint . --ext .ts --config .eslintrc.json",
    "build": "webpack && tsc --build --declaration",
    "clean": "npm run clean:build && rm -rf node_modules",
    "clean:build": "tsc --build --clean && rm -rf dist tsconfig.tsbuildinfo",
    "prepare": "npm run build"
  },
  "license": "Superblocks Community Software License",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/superblocksteam/embed-react.git"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@babel/core": "7.23.9",
    "@babel/preset-env": "7.23.9",
    "@babel/preset-react": "7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.55",
    "@types/react-dom": "18.2.19",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "babel-loader": "9.1.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-unicorn": "^51.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "webpack": "5.90.1",
    "webpack-cli": "5.1.4"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
